---
export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Integr8 | O Método Magnético',
  description = 'O Integr8 monitora 8 pilares da sua rotina para recalibrar seu plano em tempo real.',
  lang = 'pt-BR',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="noise-overlay"></div>
    <slot />
    <script>
      import { initAll } from '../scripts/app.js';
      initAll();
    </script>
  </body>
</html>
