---
import '../styles/pillars.css';
---

<section class="pillars" id="pilares">
  <div class="pillars__inner">
    <h2 class="section-title text-center fade-up">
      <span class="line">8 pilares monitorados.</span>
      <span class="line">Um único ecossistema.</span>
    </h2>
    <p class="section-desc text-center fade-up">
      Seus treinos são apenas uma pequena parte do seu dia. O que acontece nas outras restantes é o que determina
      seus resultados. O app integra todos os seus dados para que você foque apenas em viver.
    </p>

    <div class="orbit-container fade-up" data-delay="0.2">
      <div class="orbit-ring">
        <div class="orbit-center">
          <div class="orbit-center-glow"></div>
          <img
            src="/assets/images/center_couple.png"
            alt="Pessoas usando Integr8"
            class="center-img"
            loading="lazy"
            decoding="async"
            width="200" height="300"
          />
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 12V2" /><path d="M5 12a7 7 0 1 0 14 0c0-2.5-2-4.5-4.5-4.5S10 10 10 12" /><path d="M10 12c0-2 2-2 2-2s2 0 2 2" />
            </svg>
            <span>Treino</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/>
            </svg>
            <span>Nutrição</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 16v-2.38C4 11.5 2.97 10.5 3 8c.03-2.72 1.49-6 4.5-6C9.37 2 10 3.8 10 5.5c0 3.11-2 5.66-2 8.68V16a2 2 0 1 1-4 0Z"/><path d="M20 20v-2.38c0-2.12 1.03-3.12 1-5.62-.03-2.72-1.49-6-4.5-6C14.63 6 14 7.8 14 9.5c0 3.11 2 5.66 2 8.68V20a2 2 0 1 0 4 0Z"/><path d="M16 17h4"/><path d="M4 13h4"/>
            </svg>
            <span>Passos</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>
            </svg>
            <span>Hidratação</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="12" cy="10" r="3"/><path d="M12 10v3"/><path d="M3 13h18"/>
            </svg>
            <span>Pesagem</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/>
            </svg>
            <span>Fotos</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="9" x="2" y="7" rx="2" /><path d="M7 7v4" /><path d="M12 7v4" /><path d="M17 7v4" />
            </svg>
            <span>Medidas</span>
          </div>
        </div>

        <div class="pillar-orbiter">
          <div class="pillar-content">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
            <span>Sono</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
