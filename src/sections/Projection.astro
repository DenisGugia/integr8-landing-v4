---
import '../styles/projection.css';
---

<section class="projection" id="projecao" aria-label="Projeção temporal">
  <div class="projection__inner">
    <p class="proj-line proj-line--solid fade-up">OS PRÓXIMOS MESES VÃO PASSAR</p>
    <p class="proj-line proj-line--outline fade-up" data-delay="0.15">COM VOCÊ CUIDANDO DA SUA SAÚDE</p>
    <p class="proj-line proj-line--neon fade-up" data-delay="0.3">OU NÃO.</p>
    <div class="proj-break" aria-hidden="true"></div>
    <p class="proj-line proj-line--solid fade-up" data-delay="0.45">COMO VOCÊ QUER ESTAR</p>
    <p class="proj-line proj-line--solid fade-up" data-delay="0.55">QUANDO ELES PASSAREM?</p>
    <p class="proj-fineprint fade-up" data-delay="0.7">A diferença não é o tempo. É a escolha.</p>
  </div>
</section>
