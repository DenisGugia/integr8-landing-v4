---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

import Navbar    from '../components/Navbar.astro';
import Footer    from '../components/Footer.astro';
import ExitModal from '../components/ExitModal.astro';

import Hero       from '../sections/Hero.astro';
import Marquee    from '../sections/Marquee.astro';
import Story      from '../sections/Story.astro';
import Steps      from '../sections/Steps.astro';
import Pillars    from '../sections/Pillars.astro';
import Features   from '../sections/Features.astro';
import Scenarios  from '../sections/Scenarios.astro';
import Coach      from '../sections/Coach.astro';
import Profiles   from '../sections/Profiles.astro';
import Projection from '../sections/Projection.astro';
import Offer      from '../sections/Offer.astro';
import FAQ        from '../sections/FAQ.astro';
import FinalCTA   from '../sections/FinalCTA.astro';
---

<Layout title="INTEGR8 — Protocolo C.O.R.E. 8">
  <Navbar />
  <main>
    <Hero />
    <Marquee />
    <Story />
    <Steps />
    <Pillars />
    <Features />
    <Scenarios />
    <Coach />
    <Profiles />
    <Projection />
    <Offer />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <ExitModal />
</Layout>
